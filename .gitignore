# Python bytecode (auto-generated — do not commit)
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
.venv/
venv/
env/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo

# AI assistant local state
.claude/

# Local Web UI overrides (user-specific)
webui_config.json

# Cursor skills installed locally (run agent/plugin/install.py)
.cursor/

# Private strategy notes for agent (optional; see agent/private/README.md)
agent/private/STRATEGY_KNOWLEDGE.md

# Local planning / task notes (not part of the framework)
FRAMEWORK_FIXES_TO_APPLY.md
FIX_*.md
FEATURE_*.md

# Job logs from the Web UI (runtime artifacts)
webui/jobs_data/*.log
webui/jobs_data/*.json

# OS
.DS_Store
Thumbs.db

# Optional: keep example reports but ignore large personal run folders
# reports/runs/*/
